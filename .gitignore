# ─────────────────────────────────────────────────────────────
#  Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ─────────────────────────────────────────────────────────────
#  Distribution / Packaging
# ─────────────────────────────────────────────────────────────
*.egg
*.egg-info/
dist/
build/
wheels/
*.whl
sdist/

# ─────────────────────────────────────────────────────────────
#  Virtual Environments
# ─────────────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ─────────────────────────────────────────────────────────────
#  IDE / Editor
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─────────────────────────────────────────────────────────────
#  Testing & Coverage
# ─────────────────────────────────────────────────────────────
.pytest_cache/
.pytest_tmp/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ─────────────────────────────────────────────────────────────
#  Linting / Type Checking
# ─────────────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ─────────────────────────────────────────────────────────────
#  OS Files
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─────────────────────────────────────────────────────────────
#  PyTorch / ML Artifacts
# ─────────────────────────────────────────────────────────────
*.pt
*.pth
*.safetensors
*.bin
*.onnx
models/
checkpoints/

# ─────────────────────────────────────────────────────────────
#  Generated Adapters (examples output)
# ─────────────────────────────────────────────────────────────
examples/adapters/
examples/wiki/

# ─────────────────────────────────────────────────────────────
#  Script output artifacts
# ─────────────────────────────────────────────────────────────
scripts/*.txt

# ─────────────────────────────────────────────────────────────
#  Runtime Wiki Workspaces (never commit workspace content)
# ─────────────────────────────────────────────────────────────
wiki/
raw/
.obsidian/

# ─────────────────────────────────────────────────────────────
#  Misc
# ─────────────────────────────────────────────────────────────
*.log
*.bak
*.tmp
.env
.env.*
